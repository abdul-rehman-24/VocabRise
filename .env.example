# ==================================================
# VocabRise Environment Configuration
# Copy this file to .env.local and fill in your values
# ==================================================

# DATABASE CONFIGURATION
# For local PostgreSQL on Windows/Mac/Linux:
# postgres://username:password@localhost:5432/vocabrise
# 
# Make sure your PostgreSQL is running before starting the app
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/vocabrise"

# NEXTAUTH CONFIGURATION
# Generate a secret key: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-very-secret-key-here-change-this"

# OAUTH PROVIDERS - GOOGLE
# Get these from: https://console.cloud.google.com
# 1. Create a new Google OAuth App
# 2. Add http://localhost:3000/api/auth/callback/google to Authorized redirect URIs
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# CLOUDINARY CONFIGURATION (Optional - for image uploads)
# Get these from: https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==================================================
# QUICK START
# ==================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in DATABASE_URL with your PostgreSQL credentials
# 3. Generate NEXTAUTH_SECRET: openssl rand -base64 32
# 4. Add your Google OAuth credentials (optional)
# 5. Run: npm run dev
# ==================================================
