generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String?
  email         String         @unique
  passwordHash  String?
  image         String?
  bio           String?
  role          Role           @default(USER)
  emailVerified Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  authProviders AuthProvider[]
  comments      Comment[]
  likes         Like[]
  dislikes      Dislike[]
  posts         Post[]
  savedWords    SavedWord[]
  stats         UserStats?
  nominations   Nomination[]
  weeklyVotes   WeeklyVote[]
  quizAttempts  QuizAttempt[]
  notifications Notification[]

  @@map("users")
}

model AuthProvider {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_providers")
}

model WordOfDay {
  id          String      @id @default(cuid())
  word        String      @unique
  definition  String
  urduMeaning String?
  example     String
  dayIndex    Int         @unique
  difficulty  Difficulty  @default(INTERMEDIATE)
  createdAt   DateTime    @default(now())
  savedBy     SavedWord[]

  @@index([dayIndex])
  @@map("word_of_day")
}

model Post {
  id          String    @id @default(cuid())
  word        String
  definition  String
  urduMeaning String?
  example     String?
  difficulty  Difficulty @default(INTERMEDIATE)
  likesCount    Int       @default(0)
  dislikesCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  comments      Comment[]
  likes         Like[]
  dislikes      Dislike[]
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("likes")
}

model Dislike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("dislikes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model SavedWord {
  id          String     @id @default(cuid())
  userId      String
  wordOfDayId String?
  word        String
  definition  String
  urduMeaning String?
  masteryLevel  Int      @default(0)
  hasPronounced Boolean  @default(false)
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordOfDay   WordOfDay? @relation(fields: [wordOfDayId], references: [id])

  @@unique([userId, wordOfDayId])
  @@map("saved_words")
}

model UserStats {
  id             String    @id @default(cuid())
  userId         String    @unique
  totalXP        Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  wordsLearned   Int       @default(0)
  lastActiveDate DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectedWords CollectedWord[]

  @@map("user_stats")
}

model CollectedWord {
  id          String    @id @default(cuid())
  userStatsId String
  word        String
  definition  String
  category    String    @default("advanced")
  difficulty  Int       @default(3)
  masteryLevel  Int      @default(0)
  hasPronounced Boolean  @default(false)
  collectedAt DateTime  @default(now())
  userStats   UserStats @relation(fields: [userStatsId], references: [id], onDelete: Cascade)

  @@unique([userStatsId, word])
  @@index([userStatsId])
  @@map("collected_words")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Nomination {
  id          String       @id @default(cuid())
  word        String
  definition  String
  example     String?
  submittedBy User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  weekYear    Int
  weekNumber  Int
  createdAt   DateTime     @default(now())
  votes       WeeklyVote[]

  @@unique([userId, weekNumber, weekYear])
  @@index([weekNumber, weekYear])
  @@map("nominations")
}

model WeeklyVote {
  id           String     @id @default(cuid())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  nomination   Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  nominationId String
  weekYear     Int
  weekNumber   Int
  createdAt    DateTime   @default(now())

  @@unique([userId, weekNumber, weekYear])
  @@index([nominationId])
  @@map("weekly_votes")
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  score       Int
  maxScore    Int      @default(10)
  category    String?
  xpEarned    Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_attempts")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  message     String
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
